# Application
ENV=development          # development | production
APP_URL=https://qr.spoo.me
APP_NAME=QR Code Generator API
HOST=0.0.0.0
PORT=8080

# CORS
CORS_ORIGINS=["*"]

# QR code limits
QR_MAX_SIZE=1000
QR_MIN_SIZE=10

# Logging
LOG_LEVEL=DEBUG           # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console        # console | json (use json in production)
